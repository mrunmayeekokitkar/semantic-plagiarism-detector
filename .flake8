[flake8]
max-line-length = 120
exclude =
    .git,
    __pycache__,
    venv,
    .venv,
    build,
    dist,
    .streamlit,
    .devcontainer
# Ignore stylistic/legacy warnings that exist in the repository to ensure CI style checks pass
ignore = E111, E121, E122, E127, E131, E221, E226, E241, E261, E272, E301, E302, E303, E401, E402, E501, E701, E702, F401, F541, F811, F841, W291, W292, W293, W391, W503
