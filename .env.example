# ── Webhook Notifications Configuration ────────────────────────────────────────

# Webhook URL for Slack or Discord notifications.
# Supported formats:
# - Slack: <your_slack_webhook_url>
# - Discord: <your_discord_webhook_url>
PLAGIARISM_WEBHOOK_URL=

# Base URL of the running Streamlit dashboard (used in notification links).
# Default: http://localhost:8501
APP_BASE_URL=http://localhost:8501

# ── Redis Configuration ────────────────────────────────────────────────────────

# Redis connection URL (overrides individual host/port settings if provided)
# Format: redis://[password@]host:.port/db
# Example: redis://:mypassword@localhost:6379/0
REDIS_URL=

# Redis server host (fallback if REDIS_URL not set)
REDIS_HOST=localhost

# Redis server port (fallback if REDIS_URL not set)
REDIS_PORT=6379

# Redis database number (fallback if REDIS_URL not set)
REDIS_DB=0

# Redis password (if required)
REDIS_PASSWORD=
